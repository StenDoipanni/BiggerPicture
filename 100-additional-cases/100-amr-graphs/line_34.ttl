ns5:fight_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/fight-01> ;
    ns2:precedes ns5:capture_1 ;
    ns1:fight-01.first-fighter ns5:person_1 ;
    ns1:fight-01.second-fighter ns5:landscape_1 .

ns5:situation_1 a ns5:Situation .

ns5:story_1 a ns5:Story ;
    ns5:about ns5:person_2 .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/survive-01> rdfs:label "live despite" ;
    rdfs:subClassOf ns2:Event ;
    ns6:subsumedUnder <http://verbatlas.org/0486f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/trap-01> rdfs:label "to catch in or as if in  a trap, caught" ;
    rdfs:subClassOf ns2:Event ;
    ns6:subsumedUnder <http://verbatlas.org/0079f> .

ns5:base_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/base-02> ;
    ns1:base-02.decision ns5:neuter_1 ;
    ns1:base-02.justification ns5:story_1 .

ns5:capture_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/capture-01> ;
    ns1:capture-01.getter ns5:compose_1 ;
    ns1:capture-01.thing-gotten ns5:person_1 .

ns5:landscape_1 a ns5:Landscape .

ns5:person_1 a ns5:Person .

ns5:reach_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/reach-01> ;
    ns3:Time ns5:hour_1 ;
    ns1:reach-01.goal ns5:upward_1 ;
    ns1:reach-01.thing-striving ns5:man_1 .

ns5:man_1 a ns5:Man .

ns5:person_2 a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Amr:Person>,
        <https://w3id.org/framester/amr/Person> ;
