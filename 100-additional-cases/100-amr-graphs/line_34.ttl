    ns1:escape-01.entity-escaping ns5:person_2 .

ns5:hour_1 a ns5:Hour ;
    ns2:hasDataValue 127.0 ;
    ns7:hasQuantifier ns7:multiple .

ns5:ingenuity_1 a ns5:Ingenuity ;
    ns5:ingenuityOf ns5:person_2 .

ns5:isolate_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/isolate-01> ;
    ns1:isolate-01.entity-isolated ns5:man_1 .

ns5:light_1 a ns5:Light ;
    ns3:Location ns5:above_1 .

ns5:neuter_1 a ns5:Neuter .

ns5:silhouette_1 a ns5:Silhouette ;
    ns5:silhouetteOf ns5:man_1 .

ns5:struggle_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/struggle-02> ;
