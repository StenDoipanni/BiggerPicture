    ns6:subsumedUnder <http://verbatlas.org/0050f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/possible-01> rdfs:label "likely or able to be/occur" ;
    rdfs:subClassOf ns2:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/reach-01> rdfs:label "arrive at an end state, outcome or destination, get to, attain" ;
