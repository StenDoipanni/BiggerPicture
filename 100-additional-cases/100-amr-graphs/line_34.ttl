ns5:survive_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/survive-01> ;
    ns1:survive-01.survivor ns5:person_2 .

ns5:upward_1 a ns5:Upward ;
    ns3:Destination ns5:light_1 .

ns5:use_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/use-01> ;
    ns1:use-01.purpose ns5:conjunct_3 ;
    ns1:use-01.thing-used ns5:conjunct_2 ;
    ns1:use-01.user ns5:person_2 .

ns5:wall_1 a ns5:CanyonWall ;
    ns2:hasDataValue 2.0 ;
    ns2:hasQuality ns5:Massive ;
    ns7:hasQuantifier ns7:multiple .

ns5:willpower_1 a ns5:Willpower ;
    ns5:willpowerOf ns5:person_2 .

