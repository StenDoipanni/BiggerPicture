ns4:hasTruthValue a owl:ObjectProperty .

ns2:associatedWith a owl:ObjectProperty .

ns2:hasDataValue a owl:DatatypeProperty .

ns2:hasMember a owl:ObjectProperty .

ns2:hasQuality a owl:ObjectProperty .

ns2:precedes a owl:ObjectProperty .

ns5:climb_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/climb-01> ;
    ns2:precedes ns5:capture_1 ;
    ns1:climb-01.climber ns5:person_1 .

ns5:desperate_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/desperate-02> ;
    ns2:precedes ns5:reach_1 ;
    ns1:desperate-02.desparate-for-what ns5:reach_1 .

ns5:forgive_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/forgive-01> ;
    ns4:hasTruthValue ns4:False ;
    ns2:precedes ns5:fight_1 ;
    ns1:forgive-01.forgiver ns5:landscape_1 .

ns5:mean_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/mean-01> ;
    ns2:precedes ns5:reach_1 ;
    ns1:mean-01.element-containing-meaning ns5:reach_1 ;
    ns1:mean-01.meaning ns5:emphasize_1 .

ns5:natural_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/natural-03> ;
    ns2:precedes ns5:fight_1 ;
    ns1:natural-03.nature-born-entity ns5:landscape_1 .

ns5:obligate_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/obligate-01> ;
    ns2:precedes ns5:base_1 ;
    ns1:obligate-01.obligated ns5:person_2 ;
    ns1:obligate-01.obligation ns5:use_1 .

ns5:possible_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/possible-01> ;
    ns4:hasTruthValue ns4:False ;
    ns2:precedes ns5:catch_1 ;
    ns1:possible-01.thing-that-is-possible ns5:situation_1 .

ns5:trap_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/trap-01> ;
    ns2:hasQuality ns5:Between ;
    ns2:precedes ns5:reach_1 ;
    ns1:trap-01.entity-trapped ns5:man_1 ;
    ns1:trap-01.location ns5:wall_1 .

ns5:trap_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/trap-01> ;
    ns2:precedes ns5:base_1 ;
    ns3:Time ns5:person_2 ;
    ns1:trap-01.entity-trapped ns5:person_2 ;
    ns1:trap-01.location ns5:boulder_1 .

ns5:true_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/true-01> ;
    ns2:precedes ns5:base_1 ;
    ns1:true-01.truthful-thing ns5:story_1 .

