ns5:CanyonWall ns2:associatedWith ns5:Canyon ;
    rdfs:subClassOf ns5:Wall .

ns5:Neuter a owl:Thing .

ns5:above_1 a ns5:Above .

ns5:boulder_1 a ns5:Boulder .

ns5:catch_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/catch-03> ;
    ns2:precedes ns5:capture_1 ;
    ns1:catch-03.trap ns5:situation_1 ;
    ns1:catch-03.trapped ns5:person_1 .

ns5:compose_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/compose-01> ;
    ns2:hasQuality ns5:Dramatic .

ns5:conjunct_1 a ns4:Conjunct ;
    ns2:hasMember ns5:isolate_1,
        ns5:struggle_1 .

ns5:conjunct_2 a ns4:Conjunct ;
    ns2:hasMember ns5:ingenuity_1,
        ns5:willpower_1 .

ns5:conjunct_3 a ns4:Conjunct ;
    ns2:hasMember ns5:escape_1,
        ns5:survive_2 .

ns5:emphasize_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/emphasize-01> ;
    ns1:emphasize-01.emphasizer ns5:silhouette_1 ;
    ns1:emphasize-01.utterance ns5:conjunct_1 .

