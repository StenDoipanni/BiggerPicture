    ns1:be-located-at-91.entity ns5:female_1 ;
    ns1:be-located-at-91.location ns5:vehicle_1 .

ns5:conjunct_1 a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Conjunct> ;
    ns4:hasMember ns5:be-located-at_1,
