    rdfs:subClassOf ns5:Film .

ns5:Neuter a owl:Thing .

ns5:appear_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/appear-02> ;
    ns1:appear-02.thing-seeming ns5:conjunct_1 .

ns5:be-located-at_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/be-located-at-91> ;
