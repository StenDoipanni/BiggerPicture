ns1:engage-01.thing-involved-in a owl:ObjectProperty .

ns1:fill-01.container a owl:ObjectProperty .

ns1:fill-01.substance a owl:ObjectProperty .

ns1:have-03.owner a owl:ObjectProperty .

ns1:have-03.possession a owl:ObjectProperty .

ns1:intense-02.intense-thing a owl:ObjectProperty .

ns1:low-04.low-thing a owl:ObjectProperty .

ns1:low-04.the-lower-portion-of-what a owl:ObjectProperty .

ns1:navigate-01.steerer a owl:ObjectProperty .

ns1:navigate-01.thing-steered a owl:ObjectProperty .

ns1:position-01.location-or-position a owl:ObjectProperty .

