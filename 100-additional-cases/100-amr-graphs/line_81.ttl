@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns2:associatedWith a owl:ObjectProperty .

ns2:hasMember a owl:ObjectProperty .

ns2:hasQuality a owl:ObjectProperty .

ns2:precedes a owl:ObjectProperty .

ns3:appear_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/appear-02> ;
    ns2:precedes ns3:wear_1 ;
    ns1:appear-02.thing-seeming ns3:gear_1 .

ns3:brown_1 a ns3:Brown ;
    ns2:precedes ns3:have_1 ;
    ns6:Predicate ns3:wall_1 .

ns3:confine_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/confine-01> ;
    ns2:precedes ns3:position_1 ;
    ns1:confine-01.entity-confined ns3:space_1 .

ns3:dark_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/dark-02> ;
    ns2:precedes ns3:wear_1 ;
    ns1:dark-02.thing-that-doesn-t-reflect-light ns3:clothing_1 .

ns3:fill_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/fill-01> ;
    ns2:precedes ns3:navigate_1 ;
    ns1:fill-01.container ns3:area_1 ;
    ns1:fill-01.substance ns3:debris_1 .

ns3:intense_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/intense-02> ;
    ns2:precedes ns3:suggest_1 ;
    ns1:intense-02.intense-thing ns3:expression_1 .

ns3:intense_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/intense-02> ;
    ns2:precedes ns3:suggest_1 ;
    ns1:intense-02.intense-thing ns3:position_2 .

ns3:low_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/low-04> ;
    ns2:precedes ns3:position_1 ;
    ns1:low-04.low-thing ns3:position_1 ;
    ns1:low-04.the-lower-portion-of-what ns3:ground_1 .

ns3:possible_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/possible-01> ;
    ns2:precedes ns3:appear_2 ;
    ns1:possible-01.thing-that-is-possible ns3:crawl_1,
        ns3:navigate_1 .

ns3:tense_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/tense-03> ;
    ns2:precedes ns3:engage_1 ;
    ns1:tense-03.thing-tightening ns3:moment_1 .

ns3:tight_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/tight-05> ;
    ns2:precedes ns3:crawl_1 ;
    ns1:tight-05.thing-fastened-securely ns3:passage_1 .

ns6:Location a owl:ObjectProperty .

ns6:Predicate a owl:ObjectProperty .

ns5:part-of a owl:ObjectProperty .

ns1:appear-02.thing-seeming a owl:ObjectProperty .

