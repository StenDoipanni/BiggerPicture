<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#discover_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/discover-01> ;
    ns1:associatedWith <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#OrMoment> ;
