<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#figure_2> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Figure> ;
    ns1:hasQuality <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Solitary> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#float_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/float-01> ;
    ns2:float-01.benefactive <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#water_1> ;
