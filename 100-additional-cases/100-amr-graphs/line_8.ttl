    ns3:subsumedUnder <http://verbatlas.org/0227f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/surround-01> rdfs:label "be on all sides of, encompassing" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0420f> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#atmosphere_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Atmosphere> ;
    ns5:consist-of <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#conjunct_2> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#environment_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Environment> ;
