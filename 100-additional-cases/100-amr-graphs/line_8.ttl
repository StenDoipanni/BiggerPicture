<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#surround_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/surround-01> ;
    ns1:precedes <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#dwarf_1> ;
