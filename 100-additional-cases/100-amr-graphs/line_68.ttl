@prefix ns6: <https://w3id.org/framester/amr/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:associatedWith a owl:ObjectProperty .

ns1:hasMember a owl:ObjectProperty .

ns1:hasQuality a owl:ObjectProperty .

ns1:precedes a owl:ObjectProperty .

ns4:appear_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/appear-02> ;
    ns3:appear-02.thing-seeming ns4:be-from_1 .

ns4:cause_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/cause-01> ;
    ns1:precedes ns4:engulf_1 ;
    ns3:cause-01.forcer ns4:sweep_1 ;
    ns3:cause-01.impelled-action ns4:conjunct_2 .

ns4:collapse_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/collapse-01> ;
    ns1:precedes ns4:engulf_1 ;
    ns5:Time ns4:engulf_1 ;
    ns3:collapse-01.extent-of-collapse ns4:explode_1 ;
    ns3:collapse-01.thing-collapsing ns4:building_1 .

ns4:destroy_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/destroy-01> ;
    ns1:precedes ns4:consume_1 ;
    ns3:destroy-01.instrument-of-destruction ns4:wall_1 .

ns4:destroy_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/destroy-01> ;
    ns1:precedes ns4:obliterate_1 ;
    ns3:destroy-01.destroyer ns4:force_1 .

ns4:devastate_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/devastate-01> ;
    ns1:precedes ns4:create_1 ;
    ns3:devastate-01.destroyer ns4:scene_1 .

ns4:overwhelm_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/overwhelm-01> ;
    ns1:precedes ns4:sweep_1 ;
    ns3:overwhelm-01.overwhelmer ns4:force_2 .

ns4:tower_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/tower-01> ;
    ns1:precedes ns4:consume_1 ;
    ns3:tower-01.entity-rising ns4:wall_1 .

ns5:Location a owl:ObjectProperty .

ns5:Time a owl:ObjectProperty .

ns6:consist-of a owl:ObjectProperty .

ns6:subevent a owl:ObjectProperty .

