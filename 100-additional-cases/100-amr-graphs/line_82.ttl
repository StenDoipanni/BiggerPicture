ns6:fight_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/fight-01> ;
    ns1:fight-01.first-fighter ns6:person_1 ;
    ns1:fight-01.spoils ns6:survive_1 .

ns6:film_2 a ns6:Film .

ns6:gripping_1 a ns6:DramaFilm,
        <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/gripping-02> ;
    ns2:hasQuality ns6:Gripping ;
    ns2:precedes ns6:chronicle_1 ;
    ns3:hasDeterminer ns6:This .

ns6:hour_1 a ns6:Hour .

ns6:live_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/live-01> ;
