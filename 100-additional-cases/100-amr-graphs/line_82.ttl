ns6:situation_1 a ns6:die_1,
        ns6:live_1 .

ns6:state_1 a ns5:State ;
    owl:sameAs <http://dbpedia.org/resource/Utah>,
        <http://www.wikidata.org/entity/Q829> ;
    schema:name "Utah" .

ns6:struggle_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/struggle-02> ;
    ns1:struggle-02.entity-trying ns6:man_1 ;
    ns1:struggle-02.predicative-action ns6:free_1 .

ns6:survive_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/survive-01> ;
    ns7:Location ns6:wilderness_1 ;
    ns1:survive-01.survivor ns6:person_1 .

ns6:survive_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/survive-01> .

ns6:temporal-quantity_1 a ns6:Temporal-quantity ;
    ns2:hasDataValue 127.0 ;
    ns3:hasQuantifier ns3:multiple ;
    ns5:unit ns6:hour_1 .

ns6:wilderness_1 a ns6:Wilderness ;
