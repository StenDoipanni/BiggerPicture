ns2:associatedWith a owl:ObjectProperty .

ns2:hasDataValue a owl:DatatypeProperty .

ns2:hasMember a owl:ObjectProperty .

ns2:hasQuality a owl:ObjectProperty .

ns2:precedes a owl:ObjectProperty .

ns6:conjunct_1 a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Conjunct> ;
    ns2:hasMember ns6:struggle_1,
        ns6:trap_1 .

ns6:narrow_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/narrow-02> ;
    ns2:precedes ns6:trap_1 ;
    ns1:narrow-02.thing-that-is-narrow ns6:wall_1 .

ns6:pin_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/pin-01> ;
    ns2:precedes ns6:free_1 ;
    ns1:pin-01.agent ns6:boulder_1 ;
