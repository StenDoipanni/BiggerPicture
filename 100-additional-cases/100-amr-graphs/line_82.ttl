ns6:true_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/true-01> ;
    ns2:precedes ns6:depict_1 ;
    ns1:true-01.truthful-thing ns6:story_1 .

ns6:use_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/use-01> ;
    ns2:precedes ns6:chronicle_1 ;
    ns7:Time ns6:battle_1 ;
    ns1:use-01.purpose ns6:conjunct_3 ;
    ns1:use-01.thing-used ns6:conjunct_2 ;
    ns1:use-01.user ns6:person_1 .

