ns4:subsumedUnder a owl:ObjectProperty .

ns6:DramaFilm ns2:associatedWith ns6:Drama ;
    ns2:hasQuality ns6:survive_2 ;
    rdfs:subClassOf ns6:Film .

ns6:MountaineerPerson ns2:associatedWith ns6:Mountaineer ;
    rdfs:subClassOf ns6:Person .

ns6:OrSituation ns2:associatedWith ns6:Or ;
    rdfs:subClassOf ns6:Situation .

ns6:arm_1 a ns6:Arm ;
