ns3:associatedWith a owl:ObjectProperty .

ns3:hasDataValue a owl:DatatypeProperty .

ns3:hasMember a owl:ObjectProperty .

ns3:hasQuality a owl:ObjectProperty .

ns3:precedes a owl:ObjectProperty .

ns6:advanced_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/advanced-02> ;
    ns3:precedes ns6:show_1 ;
    ns1:advanced-02.progressive-entity ns6:technology_1 .

ns6:critical_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/critical-02> ;
    ns3:precedes ns6:capture_1 ;
    ns1:critical-02.situation-that-arg1-is-critical-to ns6:explore_1 ;
    ns1:critical-02.thing-that-is-crucial ns6:moment_1 .

ns6:detail_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/detail-01> ;
    ns3:precedes ns6:illuminate_1 ;
    ns1:detail-01.details ns6:structure_1 .

ns6:detail_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/detail-01> ;
    ns3:precedes ns6:illuminate_1 ;
    ns1:detail-01.details ns6:equipment_1 .

ns6:dock_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/dock-01> ;
    ns3:hasQuality ns6:Above,
        ns6:Together ;
    ns1:dock-01.destination ns6:planet_2 ;
    ns1:dock-01.thing-docked ns6:spacecraft_1 .

ns6:involve_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/involve-01> ;
    ns3:precedes ns6:highlight_1 ;
    ns1:involve-01.group ns6:operate_1 ;
    ns1:involve-01.theme ns6:engineer_1 .

ns6:require_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/require-01> ;
    ns3:precedes ns6:show_1 ;
    ns1:require-01.requirer ns6:conjunct_2 ;
    ns1:require-01.thing-required ns6:conjunct_1 .

ns7:hasQuantifier a owl:ObjectProperty .

ns4:Destination a owl:ObjectProperty .

schema:name a owl:ObjectProperty .

ns5:part-of a owl:ObjectProperty .

