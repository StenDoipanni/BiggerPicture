    ns1:hasQuality <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Eerie> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#have_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/have-03> ;
    ns1:precedes <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#stand_1> ;
