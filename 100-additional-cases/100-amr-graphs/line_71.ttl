<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#left_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/left-20> ;
    ns1:precedes <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#loom_1> ;
