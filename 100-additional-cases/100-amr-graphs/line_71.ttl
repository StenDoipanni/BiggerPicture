    ns2:realize-01.new-knower <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#character_1> ;
    ns2:realize-01.new-knowledge <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#present_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#scene_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Scene> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#skull_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Skull> ;
    ns1:hasQuality <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Grotesque> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#spirit_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Spirit> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/appear-02> rdfs:label "seem, appear, be unmistakable (for/as)" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0511f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/cast-01> rdfs:label "throw outward, throw (dice, fishing lines, shadows)" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0234f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/confront-01> rdfs:label "to engage in confrontation, confronting, challenging, beingin conflict with another" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0373f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/dark-02> rdfs:label "not reflecting much, if any, light" ;
    rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/glow-01> rdfs:label "to shine brightly and steadily, to be radiant" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0501f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/green-02> rdfs:label "be green in color" ;
    rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/have-03> rdfs:label "own, possess" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0104f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/left-20> rdfs:label "be located on the left side" ;
    rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/light-04> rdfs:label "to set on fire or make lighter" ;
    rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/loom-01> rdfs:label "appear in a threatening manner" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0288f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/menace-01> rdfs:label "threaten" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0461f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/present-02> rdfs:label "in attendance" ;
    rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/realize-01> rdfs:label "come to know" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0093f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/serious-02> rdfs:label "grave, of great importance" ;
    rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/stand-01> rdfs:label "(cause to) be in a vertical position" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0361f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/tense-03> rdfs:label "be tight(er)" ;
    rdfs:subClassOf ns1:Event .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#appear_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/appear-02> ;
    ns2:appear-02.thing-seeming <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Moment> .

