    ns2:left-20.to-the-left-of <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#frame_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#menace_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/menace-01> ;
    ns1:precedes <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#stand_1> ;
