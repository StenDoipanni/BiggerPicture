        <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#skull_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#disjunct_3> a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Disjunct> ;
    ns1:hasMember <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#monster_1>,
        <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#spirit_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#face_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#DemonFace> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#frame_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Frame> .

