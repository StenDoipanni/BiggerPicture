    ns2:cast-01.thing-thrown <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#glow_1> ;
    ns2:cast-01.thrower <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#lighting_1> .

