<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#tense_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/tense-03> ;
    ns1:precedes <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#appear_1> ;
    ns2:tense-03.thing-tightening <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Moment> .

ns4:Location a owl:ObjectProperty .

ns4:Time a owl:ObjectProperty .

