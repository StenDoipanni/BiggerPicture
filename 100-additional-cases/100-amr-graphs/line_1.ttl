ns6:encounter_3 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/encounter-01> ;
    ns4:encounter-01.entity-encountering-something ns6:cinema_1 .

ns6:flare_1 a ns6:Flare ;
    ns6:flareOf ns6:person_1 .

ns6:ground_1 a ns6:Ground ;
    ns6:groundOf ns6:person_1 .

