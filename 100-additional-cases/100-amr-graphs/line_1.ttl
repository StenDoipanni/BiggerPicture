    ns4:have-degree-91.domain ns6:encounter_2 ;
    ns4:have-degree-91.superlative ns6:encounter_3 .

ns6:pour_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/pour-01> ;
    ns1:precedes ns6:face-off_1 ;
    ns4:pour-01.liquid ns6:rain_1 .

ns6:red_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/red-02> ;
