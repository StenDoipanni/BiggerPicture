    ns4:red-02.red-entity ns6:glow_1 .

ns6:tower_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/tower-01> ;
    ns1:precedes ns6:loom_1 ;
    ns4:tower-01.entity-rising ns6:dinosaur_3 .

