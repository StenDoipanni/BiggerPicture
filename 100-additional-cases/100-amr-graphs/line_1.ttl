    ns1:precedes ns6:loom_1 ;
    ns4:damage-01.entity-damaged ns6:jeep_1 .

ns6:dark_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/dark-02> ;
    ns1:precedes ns6:illuminate_1 ;
    ns4:dark-02.thing-that-doesn-t-reflect-light ns6:night_1 .

ns6:defend_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/defend-01> ;
    ns1:precedes ns6:arm_1 ;
    ns4:defend-01.instrument ns6:weapon_1 .

ns6:fill_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/fill-01> ;
    ns1:precedes ns6:capture_1 ;
    ns4:fill-01.container ns6:confront_1 ;
