    ns3:subsumedUnder <http://verbatlas.org/0570f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/red-02> rdfs:label "be the color red" ;
    rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/remember-01> rdfs:label "default, to recall" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0076f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/stand-01> rdfs:label "(cause to) be in a vertical position" ;
