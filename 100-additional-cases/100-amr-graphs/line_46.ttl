ns1:associatedWith a owl:ObjectProperty .

ns1:hasMember a owl:ObjectProperty .

ns1:hasQuality a owl:ObjectProperty .

ns1:precedes a owl:ObjectProperty .

ns5:appear_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/appear-02> ;
    ns4:appear-02.thing-seeming ns5:disjunct_1 .

ns5:damage_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/damage-01> ;
    ns1:precedes ns5:gather_1 ;
    ns4:damage-01.entity-damaged ns5:vehicle_1 .

ns5:harsh_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/harsh-02> ;
    ns1:precedes ns5:depict_1 ;
    ns4:harsh-02.harsh-entity ns5:reality_1 .

ns5:have-degree_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/have-degree-91> ;
    ns1:precedes ns5:look_1 ;
    ns4:have-degree-91.attribute ns5:close_1 ;
    ns4:have-degree-91.degree-itself ns5:more_1 ;
    ns4:have-degree-91.domain ns5:look_1 .

ns5:muddy_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/muddy-01> ;
    ns1:precedes ns5:gather_1 ;
    ns4:muddy-01.thing-obscured ns5:environment_1 .

ns5:possible_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/possible-01> ;
    ns1:precedes ns5:depict_1 ;
    ns4:possible-01.thing-that-is-possible ns5:see_1 .

ns5:surround_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/surround-01> ;
    ns1:precedes ns5:see_1 ;
    ns4:surround-01.thing-surrounded ns5:combat_1 ;
    ns4:surround-01.thing-surrounding ns5:area_1 .

ns5:tear_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/tear-01> ;
    ns1:precedes ns5:gather_1 ;
    ns4:tear-01.puller ns5:war_1 ;
    ns4:tear-01.thing-torn ns5:environment_1 .

ns5:wear_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/wear-01> ;
    ns1:precedes ns5:gather_1 ;
    ns4:wear-01.clothing ns5:conjunct_1 ;
    ns4:wear-01.wearer ns5:soldier_1 .

ns7:hasQuantifier a owl:ObjectProperty .

