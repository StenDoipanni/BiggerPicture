    ns2:precedes ns5:glide_1 ;
    ns4:deep-02.deep-thing ns5:water_1 ;
    ns4:deep-02.extending-where ns5:blue_1 .

ns5:grace_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/grace-01> ;
    ns2:hasQuality ns5:Predatory ;
    ns2:precedes ns5:glide_1 ;
    ns4:grace-01.entity-beautified ns5:move_1 .

ns5:have-degree_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/have-degree-91> ;
    ns2:precedes ns5:accompany_1 ;
    ns4:have-degree-91.attribute ns5:small_1 ;
    ns4:have-degree-91.degree-itself ns5:more_1 ;
    ns4:have-degree-91.domain ns5:fish_1 .

ns5:light_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/light-04> ;
    ns2:precedes ns5:suggest_1 ;
    ns4:light-04.setter-of-fire ns5:thing_1 .

ns5:natural_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/natural-03> ;
    ns2:precedes ns5:create_1 ;
    ns4:natural-03.nature-born-entity ns5:habitat_1 .

ns5:open_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/open-06> ;
    ns2:precedes ns5:take_1 ;
    ns4:open-06.spacious-place ns5:ocean_2 .

ns5:powerful_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/powerful-02> ;
    ns2:precedes ns5:glide_1 ;
    ns4:powerful-02.powerful-entity ns5:body_1 .

ns5:swim_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/swim-01> ;
    ns2:precedes ns5:accompany_1 ;
    ns4:swim-01.course ns5:fish_1 ;
    ns4:swim-01.to-where ns5:nearby_1 .

ns5:white_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/white-03> ;
    ns2:hasQuality ns5:Great ;
    ns2:precedes ns5:glide_1 ;
    ns4:white-03.thing-that-is-white-in-color ns5:shark_1 .

