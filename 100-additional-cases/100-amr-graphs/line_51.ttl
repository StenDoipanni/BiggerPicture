    ns2:subsumedUnder <http://verbatlas.org/0162f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/desperate-02> rdfs:subClassOf ns3:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/endanger-01> rdfs:label "to expose to harm or danger, having potential to harm" ;
    rdfs:subClassOf ns3:Event ;
    ns2:subsumedUnder <http://verbatlas.org/0461f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/fame-01> rdfs:label "well known, popular, renowned" ;
    rdfs:subClassOf ns3:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/involve-01> rdfs:label "include, connected, associated, wrapped up in" ;
    rdfs:subClassOf ns3:Event ;
    ns2:subsumedUnder <http://verbatlas.org/0080f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/lie-07> rdfs:label "assume a horizontal position, more generally 'exist', existing" ;
    rdfs:subClassOf ns3:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/loom-01> rdfs:label "appear in a threatening manner" ;
    rdfs:subClassOf ns3:Event ;
    ns2:subsumedUnder <http://verbatlas.org/0288f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/struggle-02> rdfs:label "try very hard" ;
    rdfs:subClassOf ns3:Event ;
    ns2:subsumedUnder <http://verbatlas.org/0331f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/tense-03> rdfs:label "be tight(er)" ;
