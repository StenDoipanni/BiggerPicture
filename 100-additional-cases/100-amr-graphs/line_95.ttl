    ns1:capture-01.getter ns6:scene_1 ;
    ns1:capture-01.thing-gotten ns6:moment_1 .

ns6:contrast_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/contrast-01> ;
    ns2:hasQuality ns6:Dramatic ;
    ns1:contrast-01.first-item-in-comparison ns6:figure_2 ;
    ns1:contrast-01.second-item-in-comparison ns6:sky_1 .

ns6:figure_1 a ns6:Figure .

ns6:form_1 a ns6:Form ;
    ns2:hasQuality ns6:Human,
        ns6:Solitary .

ns6:frame_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/frame-03> ;
