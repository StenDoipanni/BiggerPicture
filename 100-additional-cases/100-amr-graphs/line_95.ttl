ns6:scene_1 a ns6:Scene .

ns6:struggle_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/struggle-01> .

ns6:tree_1 a ns6:Tree .

ns6:trunk_1 a ns6:Trunk ;
    ns2:hasQuality ns6:Large ;
    ns4:part-of ns6:tree_1 .

ns6:upward_1 a ns6:Upward .

