ns6:OrMoment ns2:associatedWith ns6:Or ;
    rdfs:subClassOf ns6:Moment .

ns6:above_1 a ns6:Above .

ns6:branch_2 a ns6:Branch ;
    ns2:hasQuality ns6:Gnar ;
    ns2:precedes ns6:frame_1 ;
    ns4:part-of ns6:tree_2 .

ns6:canopy_1 a ns6:Canopy ;
    ns4:part-of ns6:forest_1 .

ns6:compose_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/compose-01> .

ns6:conjunct_1 a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Conjunct> ;
    ns2:hasMember ns6:power_1,
        ns6:scale_1 .

ns6:conjunct_2 a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Conjunct> ;
    ns2:hasMember ns6:branch_2,
        ns6:tree_2 .

ns6:explore_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/explore-01> ;
    ns2:associatedWith ns6:OrMoment .

ns6:filter_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/filter-02> ;
    ns2:precedes ns6:capture_1 ;
    ns5:Location ns6:foliage_1 ;
    ns1:filter-02.solids ns6:sunlight_1 .

ns6:forest_1 a ns6:Forest ;
    ns2:hasQuality ns6:Dense ;
    ns2:precedes ns6:reach_1 .

ns6:moment_1 a ns6:explore_1,
        ns6:struggle_1 .

ns6:power_1 a ns6:Power ;
    ns6:powerOf ns6:nature_1 .

ns6:scale_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/scale-01> ;
