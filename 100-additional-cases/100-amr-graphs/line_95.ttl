ns6:thick_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/thick-03> ;
    ns2:precedes ns6:reach_1 ;
    ns1:thick-03.thing-with-a-wide-diameter ns6:branch_1 .

ns6:tower_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/tower-01> ;
    ns2:precedes ns6:frame_1 ;
