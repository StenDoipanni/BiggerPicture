ns2:associatedWith a owl:ObjectProperty .

ns2:hasMember a owl:ObjectProperty .

ns2:hasQuality a owl:ObjectProperty .

ns2:precedes a owl:ObjectProperty .

ns6:bright_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/bright-02> ;
    ns2:precedes ns6:contrast_1 ;
    ns1:bright-02.location-illuminated ns6:sky_1 .

ns6:create_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/create-01> ;
    ns2:precedes ns6:stand_1 ;
    ns1:create-01.creator ns6:capture_1 ;
    ns1:create-01.thing-created ns6:contrast_1 .

ns6:dapple_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/dapple-01> ;
    ns2:precedes ns6:capture_1 ;
    ns1:dapple-01.thing-dappled ns6:sunlight_1 .

ns6:dark_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/dark-02> ;
    ns2:precedes ns6:contrast_1 ;
    ns1:dark-02.thing-that-doesn-t-reflect-light ns6:figure_2 .

ns6:emphasize_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/emphasize-01> ;
    ns1:emphasize-01.emphasizer ns6:compose_1 ;
    ns1:emphasize-01.utterance ns6:conjunct_1 .

ns6:engage_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/engage-01> ;
    ns2:precedes ns6:frame_1 ;
    ns1:engage-01.entity-sucked-in ns6:form_1 ;
    ns1:engage-01.thing-involved-in ns6:interact_1 .

ns6:green_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/green-02> ;
    ns2:precedes ns6:filter_1 ;
    ns1:green-02.green-thing ns6:foliage_1 .

ns6:natural_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/natural-03> ;
    ns2:precedes ns6:interact_1 ;
    ns1:natural-03.nature-born-entity ns6:environment_1 .

ns6:silhouet_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/silhouet-01> ;
    ns2:precedes ns6:stand_1 ;
    ns5:Cause ns6:trunk_1 ;
