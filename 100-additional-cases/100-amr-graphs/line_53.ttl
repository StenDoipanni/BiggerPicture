    rdfs:subClassOf ns5:Event ;
    ns6:subsumedUnder <http://verbatlas.org/0301f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/cause-01> rdfs:label "impelled action" ;
    rdfs:subClassOf ns5:Event ;
    ns6:subsumedUnder <http://verbatlas.org/0619f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/cling-01> rdfs:label "stick to, overly obsessive lover" ;
    rdfs:subClassOf ns5:Event ;
    ns6:subsumedUnder <http://verbatlas.org/0419f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/convey-01> rdfs:label "send (a statement)" ;
    rdfs:subClassOf ns5:Event ;
    ns6:subsumedUnder <http://verbatlas.org/0177f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/despair-01> rdfs:label "to give up hope" ;
