    ns6:subsumedUnder <http://verbatlas.org/0582f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/emphasize-01> rdfs:label "emphasize" ;
    rdfs:subClassOf ns5:Event ;
    ns6:subsumedUnder <http://verbatlas.org/0312f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/endanger-01> rdfs:label "to expose to harm or danger, having potential to harm" ;
    rdfs:subClassOf ns5:Event ;
    ns6:subsumedUnder <http://verbatlas.org/0461f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/find-01> rdfs:label "discovery" ;
    rdfs:subClassOf ns5:Event ;
    ns6:subsumedUnder <http://verbatlas.org/0033f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/intense-02> rdfs:label "extreme, rich, concentrated" ;
    rdfs:subClassOf ns5:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/isolate-01> rdfs:label "to set apart, (causing to be) solitary" ;
    rdfs:subClassOf ns5:Event ;
    ns6:subsumedUnder <http://verbatlas.org/0307f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/overcast-01> rdfs:label "cast over" ;
    rdfs:subClassOf ns5:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/show-01> rdfs:label "cause to see" ;
    rdfs:subClassOf ns5:Event ;
    ns6:subsumedUnder <http://verbatlas.org/0162f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/signal-07> rdfs:label "show, cause to see, communicate by signaling, message" ;
    rdfs:subClassOf ns5:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/strand-01> rdfs:label "to leave stranded, left high and dry" ;
    rdfs:subClassOf ns5:Event ;
    ns6:subsumedUnder <http://verbatlas.org/0253f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/struggle-02> rdfs:label "try very hard" ;
    rdfs:subClassOf ns5:Event ;
    ns6:subsumedUnder <http://verbatlas.org/0331f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/survive-01> rdfs:label "live despite" ;
    rdfs:subClassOf ns5:Event ;
    ns6:subsumedUnder <http://verbatlas.org/0486f> .

ns2:capture_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/capture-01> ;
    ns1:capture-01.getter ns2:scene_1 ;
    ns1:capture-01.thing-gotten ns2:moment_1 .

ns2:expression_1 a ns2:Expression ;
    ns5:hasQuality ns2:Wild .

ns2:man_3 a ns2:Man ;
    ns2:with ns2:expression_1 .

ns2:sky_1 a ns2:Sky .

ns2:thing_1 a ns2:Thing .

ns2:toll_1 a ns2:EmotionToll ;
    ns5:hasQuality ns2:Physical .

