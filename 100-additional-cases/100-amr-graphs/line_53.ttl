    ns1:beard-02.patient ns2:man_1 .

ns2:cause_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/cause-01> ;
    ns5:precedes ns2:convey_1 ;
    ns4:Predicate ns2:toll_1 ;
    ns1:cause-01.forcer ns2:strand_1 .

ns2:endanger_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/endanger-01> ;
    ns5:precedes ns2:emphasize_1 ;
    ns1:endanger-01.exposer-to-danger ns2:circumstance_1 .

ns2:find_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/find-01> ;
