    ns5:precedes ns2:capture_1 ;
    ns1:intense-02.intense-thing ns2:moment_1 .

ns2:isolate_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/isolate-01> ;
    ns5:precedes ns2:emphasize_1 ;
    ns1:isolate-01.entity-isolated ns2:circumstance_1 .

ns2:overcast_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/overcast-01> ;
    ns5:precedes ns2:emphasize_1 ;
    ns1:overcast-01.thing-or-area-being-enclosed ns2:sky_1 .

ns2:peril_1 a ns2:Peril ;
