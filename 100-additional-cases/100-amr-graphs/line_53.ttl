ns2:survive_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/survive-01> ;
    ns1:survive-01.survivor ns2:man_2 .

ns2:water_1 a ns2:TurbulenceWater .

ns2:water_2 a ns2:Water ;
    ns5:hasQuality ns2:Choppy ;
    ns5:precedes ns2:emphasize_1 ;
    ns4:Location ns2:background_1 .

ns2:wreckage_1 a ns2:Wreckage .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/beard-02> rdfs:label "furnish with a beard" ;
    rdfs:subClassOf ns5:Event .

