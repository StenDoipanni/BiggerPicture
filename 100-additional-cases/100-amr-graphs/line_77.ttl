ns3:associatedWith a owl:ObjectProperty .

ns3:hasMember a owl:ObjectProperty .

ns3:hasQuality a owl:ObjectProperty .

ns3:precedes a owl:ObjectProperty .

ns6:appear_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/appear-02> ;
    ns3:precedes ns6:move_1 ;
    ns1:appear-02.thing-seeming ns6:thing_1 ;
    ns1:appear-02.viewer ns6:disjunct_1 .

ns6:convey_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/convey-01> ;
    ns3:precedes ns6:capture_1 ;
    ns1:convey-01.sender ns6:conjunct_2 ;
    ns1:convey-01.thing-sent ns6:sense_1 .

ns6:create_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/create-01> ;
    ns3:precedes ns6:surround_1 ;
    ns1:create-01.creator ns6:tree_1 ;
    ns1:create-01.thing-created ns6:atmosphere_1 .

ns6:deep_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/deep-02> ;
    ns3:precedes ns6:wear_1 ;
    ns2:Predicate <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#malformed_amr/z12> ;
    ns1:deep-02.deep-thing ns6:red_1 .

ns6:deliberate_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/deliberate-01> ;
    ns3:precedes ns6:capture_1 ;
    ns1:deliberate-01.thought ns6:pace_1 .

ns6:line_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/line-01> ;
    ns3:precedes ns6:walk_1 ;
    ns1:line-01.instrument ns6:tree_2 ;
    ns1:line-01.thing-lined ns6:path_1 .

ns6:quiet_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/quiet-04> ;
    ns3:precedes ns6:capture_1 ;
    ns1:quiet-04.quiet-entity ns6:practice_1 .

ns6:quiet_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/quiet-04> ;
    ns3:precedes ns6:capture_1 ;
    ns1:quiet-04.quiet-entity ns6:ritual_1 .

ns6:silhouet_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/silhouet-01> ;
    ns3:precedes ns6:move_1 ;
    ns2:Cause ns6:darkness_1 ;
    ns2:Expreriencer ns6:figure_1 .

ns2:Cause a owl:ObjectProperty .

ns2:Expreriencer a owl:ObjectProperty .

ns2:Instrument a owl:ObjectProperty .

ns2:Location a owl:ObjectProperty .

ns2:Predicate a owl:ObjectProperty .

ns2:Time a owl:ObjectProperty .

schema:name a owl:ObjectProperty .

ns5:consist-of a owl:ObjectProperty .

ns5:manner a owl:ObjectProperty,
        ns4:SemanticRole ;
    owl:equivalentProperty <https://w3id.org/framester/data/propbank-3.4.0/GenericRole/manner> .

ns7:dayperiod a owl:ObjectProperty .

ns1:appear-02.thing-seeming a owl:ObjectProperty .

ns1:appear-02.viewer a owl:ObjectProperty .

ns1:capture-01.getter a owl:ObjectProperty .

ns1:capture-01.thing-gotten a owl:ObjectProperty .

ns1:convey-01.sender a owl:ObjectProperty .

ns1:convey-01.thing-sent a owl:ObjectProperty .

