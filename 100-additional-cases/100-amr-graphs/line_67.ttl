    ns2:have-03.owner ns4:landscape_1 ;
    ns2:have-03.possession ns4:conjunct_1 .

ns4:move_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/move-01> ;
    ns2:move-01.moved ns4:unit_1 .

ns4:operate_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/operate-01> ;
    ns3:associatedWith ns4:Combat-01 .

ns4:operate_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/operate-01> ;
