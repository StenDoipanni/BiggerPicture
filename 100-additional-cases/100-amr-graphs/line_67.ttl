ns2:travel-01.traveller a owl:ObjectProperty .

ns1:subsumedUnder a owl:ObjectProperty .

ns4:DesertEnvironment ns3:associatedWith ns4:Desert ;
    rdfs:subClassOf ns4:Environment .

ns4:TacticUnit ns3:associatedWith ns4:Tactic ;
    rdfs:subClassOf ns4:Unit .

ns4:activity_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/activity-06> ;
    ns3:precedes ns4:travel_1 ;
    ns2:activity-06.activity-engaged-in ns4:appear_1 .

ns4:around_1 a ns4:Around .

ns4:conjunct_1 a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Conjunct> ;
    ns3:hasMember ns4:tree_1,
        ns4:vegetation_1 .

ns4:conjunct_2 a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Conjunct> ;
    ns3:hasMember ns4:vehicle_2 ;
    ns3:hasQuality ns4:On .

ns4:conjunct_3 a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Conjunct> ;
    ns3:hasMember ns4:coordinate_1,
        ns4:move_2 .

ns4:convoy_1 a ns4:Convoy ;
    ns3:hasQuality ns4:Military ;
    ns6:consist-of ns4:vehicle_1 .

ns4:coordinate_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/coordinate-01> ;
    ns2:coordinate-01.entity-coordinated ns4:unit_1 .

ns4:disjunct_1 a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Disjunct> ;
