ns4:possible_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/possible-01> ;
    ns2:possible-01.thing-that-is-possible ns4:see_1 .

ns4:scatter_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/scatter-01> ;
    ns3:precedes ns4:have_1 ;
    ns5:Predicate ns4:vegetation_1 ;
