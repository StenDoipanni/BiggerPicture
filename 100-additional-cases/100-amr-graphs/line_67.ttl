ns3:associatedWith a owl:ObjectProperty .

ns3:hasMember a owl:ObjectProperty .

ns3:hasQuality a owl:ObjectProperty .

ns3:precedes a owl:ObjectProperty .

ns4:activity_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/activity-06> ;
    ns3:precedes ns4:capture_1 ;
    ns2:activity-06.active-entity ns4:person_1 ;
    ns2:activity-06.activity-engaged-in ns4:mission_1 .

ns4:activity_3 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/activity-06> ;
