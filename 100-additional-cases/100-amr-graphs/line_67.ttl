ns4:scene_1 a ns4:Scene .

ns4:see_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/see-01> ;
    ns2:see-01.thing-viewed ns4:position_1 .

ns4:vehicle_1 a ns4:Vehicle .

ns4:vehicle_2 a ns4:Vehicle ;
