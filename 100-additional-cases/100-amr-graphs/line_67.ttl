        ns4:operate_2 .

ns4:disjunct_2 a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Disjunct> ;
    ns3:hasMember ns4:engage_1,
        ns4:mission_1 .

ns4:environment_1 a ns4:DesertEnvironment .

ns4:form_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/form-01> ;
    ns2:form-01.thing-created ns4:soldier_1 .

ns4:have_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/have-03> ;
