<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/calm-03> rdfs:label "still, relaxed" ;
    rdfs:subClassOf ns2:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/clear-08> rdfs:label "unobstructed, clean, open" ;
    rdfs:subClassOf ns2:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/create-01> rdfs:label "create" ;
