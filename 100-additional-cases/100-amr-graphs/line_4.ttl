<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/low-04> rdfs:label "be in the lower ranges" ;
    rdfs:subClassOf ns2:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/operate-01> rdfs:label "cf work, working (of something)" ;
    rdfs:subClassOf ns2:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0183f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/rise-01> rdfs:label "go up" ;
    rdfs:subClassOf ns2:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0430f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/shine-01> rdfs:label "produce light" ;
    rdfs:subClassOf ns2:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0501f> .

