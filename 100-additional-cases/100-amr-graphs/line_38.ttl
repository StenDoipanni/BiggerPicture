ns3:associatedWith a owl:ObjectProperty .

ns3:hasDataValue a owl:DatatypeProperty .

ns3:hasMember a owl:ObjectProperty .

ns3:hasQuality a owl:ObjectProperty .

ns3:precedes a owl:ObjectProperty .

ns2:accrete_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/accrete-01> ;
    ns3:precedes ns2:dominate_1 ;
    ns1:accrete-01.accreting-entity ns2:disk_1 .

ns2:black_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/black-04> ;
    ns3:precedes ns2:dominate_1 ;
    ns1:black-04.thing-that-is-black-in-color ns2:hole_1 .

ns2:black_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/black-04> ;
    ns3:precedes ns2:fall_1 ;
    ns1:black-04.thing-that-is-black-in-color ns2:hole_2 .

ns2:curve_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/curve-01> ;
    ns3:precedes ns2:display_1 ;
    ns1:curve-01.curved-thing ns2:stream_2 .

ns2:intense_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/intense-02> ;
    ns3:precedes ns2:dominate_1 ;
    ns1:intense-02.intense-thing ns2:bright_1 .

ns2:mesmerize_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/mesmerize-01> ;
    ns3:precedes ns2:create_2 ;
    ns1:mesmerize-01.mesmerizer ns2:display_1 .

ns2:near_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/near-01> ;
    ns3:precedes ns2:showcase_1 ;
    ns1:near-01.destination ns2:speed_1 ;
    ns1:near-01.entity-in-motion ns2:fall_1 .

ns2:stream_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/stream-01> ;
    ns3:precedes ns2:create_1 ;
    ns5:Destination ns2:darkness_1,
        ns2:outward_1 ;
    ns1:stream-01.substance-leaked ns2:jet_1 .

ns2:swirl_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/swirl-01> ;
    ns3:precedes ns2:create_1 ;
    ns1:swirl-01.thing-in-motion ns2:light_1 .

ns2:twist_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/twist-01> ;
    ns3:precedes ns2:display_1 ;
    ns5:Location ns2:horizon_1 ;
    ns1:twist-01.entity-twisted ns2:stream_2 .

