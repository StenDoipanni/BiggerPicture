@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns2:associatedWith a owl:ObjectProperty .

ns2:hasDataValue a owl:DatatypeProperty .

ns2:hasMember a owl:ObjectProperty .

ns2:hasQuality a owl:ObjectProperty .

ns2:precedes a owl:ObjectProperty .

ns5:conjunct_2 a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Conjunct> ;
    ns2:hasMember ns5:recline_1,
        ns5:see_1,
        ns5:stand_2 .

ns5:inhabit_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/inhabit-01> ;
    ns2:precedes ns5:juxtapose_1 ;
    ns1:inhabit-01.place-of-residence ns5:house_2 ;
    ns1:inhabit-01.resident ns5:person_3 .

ns5:manicure_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/manicure-01> ;
    ns2:precedes ns5:stand_1 ;
    ns1:manicure-01.nails ns5:lawn_1 .

ns5:modern_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/modern-02> ;
    ns2:precedes ns5:stand_1 ;
    ns1:modern-02.thing-being-modernized ns5:conjunct_1 .

ns5:near_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/near-02> ;
    ns2:precedes ns5:stand_2 ;
    ns1:near-02.in-relation-to ns5:architecture_1 ;
    ns1:near-02.nearby-entity ns5:background_1 .

ns5:position_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/position-01> ;
    ns1:position-01.location-or-position ns5:property_1 ;
    ns1:position-01.thing-positioned ns5:figure_1 .

ns5:tense_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/tense-03> ;
    ns2:precedes ns5:capture_1 ;
    ns1:tense-03.thing-tightening ns5:moment_1 .

ns5:underlie_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/underlie-01> ;
    ns2:precedes ns5:juxtapose_1 ;
    ns1:underlie-01.foundation-for-what ns5:conflict_1 ;
    ns1:underlie-01.thing-acting-as-a-foundation ns5:sense_1 .

ns6:hasDeterminer a owl:ObjectProperty .

ns6:hasQuantifier a owl:ObjectProperty .

ns4:Location a owl:ObjectProperty .

schema:name a owl:ObjectProperty .

ns7:consist-of a owl:ObjectProperty .

ns7:manner a owl:ObjectProperty,
        ns3:SemanticRole ;
    owl:equivalentProperty <https://w3id.org/framester/data/propbank-3.4.0/GenericRole/manner> .

ns7:medium a owl:ObjectProperty,
        ns3:SemanticRole ;
    owl:equivalentProperty <https://w3id.org/framester/data/propbank-3.4.0/GenericRole/medium> .

ns7:part-of a owl:ObjectProperty .

