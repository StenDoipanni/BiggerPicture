ns7:prevent_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/prevent-01> ;
    ns2:prevent-01.agent ns7:person_1 ;
    ns2:prevent-01.theme ns7:catastrophe_1 .

ns7:street_1 a ns7:Street .

ns7:tactic_1 a ns7:Tactic .

ns7:tension_1 a ns7:Tension .

ns7:vehicle_1 a ns7:Vehicle .

ns7:weapon_1 a ns7:Weapon .

ns7:work_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/work-01> ;
    ns1:hasQuality ns7:Against ;
    ns4:Time ns7:conjunct_3 ;
    ns6:manner ns7:clock_1 ;
    ns2:work-01.job ns7:prevent_1 ;
    ns2:work-01.worker ns7:person_1 .

