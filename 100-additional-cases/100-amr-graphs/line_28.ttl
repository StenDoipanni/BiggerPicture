<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/unfold-01> rdfs:label "cause to become unfolded" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0289f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/work-01> rdfs:label "work, being employed, acts, deeds (no physical parts or gov't departments!)" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0597f> .

ns7:bomb_1 a ns7:Bomb .

ns7:bus_1 a ns7:CityBus .

ns7:conjunct_2 a ns5:Conjunct ;
    ns1:hasMember ns7:tactic_1,
        ns7:weapon_1 .

ns7:deal_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/deal-01> ;
