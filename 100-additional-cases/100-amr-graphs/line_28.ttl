<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/obligate-01> rdfs:label "impelled action" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0050f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/pass-03> rdfs:label "go by" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0111f>,
        <http://verbatlas.org/0333f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/plant-01> rdfs:label "to put or place, sewing in the ground" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0361f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/possible-01> rdfs:label "likely or able to be/occur" ;
    rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/prevent-01> rdfs:label "stop, prevent, stopping in advance" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0181f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/race-01> rdfs:label "run very fast, moving very quickly (non-competitive, manner motion)" ;
    rdfs:subClassOf ns1:Event ;
