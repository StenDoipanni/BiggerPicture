ns7:ActionThriller ns1:associatedWith ns7:Action ;
    rdfs:subClassOf ns7:Thriller .

ns7:CityBus ns1:associatedWith ns7:City ;
    rdfs:subClassOf ns7:Bus .

ns7:HeroPerson ns1:associatedWith ns7:Hero ;
    rdfs:subClassOf ns7:Person .

ns7:catastrophe_1 a ns7:Catastrophe .

ns7:clock_1 a ns7:Clock .

ns7:conjunct_1 a ns5:Conjunct ;
    ns1:hasMember ns7:law_1,
        ns7:person_2 ;
    ns4:Predicate ns7:officer_1 .

ns7:conjunct_3 a ns5:Conjunct ;
    ns1:hasMember ns7:deal_1,
        ns7:manage_1 .

ns7:conjunct_4 a ns5:Conjunct ;
    ns1:hasMember ns7:person_4,
        ns7:person_5 .

ns7:law_1 a ns7:Law .

ns7:law_2 a ns7:Law .

ns7:mount_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/mount-02> ;
