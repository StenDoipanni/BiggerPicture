    ns1:precedes ns7:unfold_1 ;
    ns4:Time ns7:force_1 ;
    ns2:mount-02.climber ns7:tension_1 .

ns7:obligate_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/obligate-01> ;
    ns2:obligate-01.obligated ns7:person_1 ;
    ns2:obligate-01.obligation ns7:work_1 .

ns7:officer_1 a ns7:Officer ;
