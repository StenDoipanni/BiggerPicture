ns5:hasTruthValue a owl:ObjectProperty .

ns1:associatedWith a owl:ObjectProperty .

ns1:hasMember a owl:ObjectProperty .

ns1:hasPrecondition a owl:ObjectProperty .

ns1:hasQuality a owl:ObjectProperty .

ns1:precedes a owl:ObjectProperty .

ns7:bomb_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/bomb-01> ;
    ns1:precedes ns7:deal_1 ;
    ns2:bomb-01.attacker ns7:person_3 .

ns7:crime_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/crime-02> ;
    ns1:precedes ns7:have-org-role_1 ;
    ns2:crime-02.criminal ns7:person_2 .

ns7:crime_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/crime-02> ;
    ns1:precedes ns7:force_1 ;
    ns2:crime-02.criminal ns7:person_5 .

ns7:desperate_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/desperate-02> ;
    ns1:precedes ns7:force_1 ;
    ns2:desperate-02.desparate-for-what ns7:race_1 .

ns7:detonate_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/detonate-01> ;
    ns1:hasPrecondition ns7:slow-down_1 ;
    ns1:precedes ns7:plant_1 ;
    ns2:detonate-01.bomb ns7:bomb_1 .

ns7:enforce_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/enforce-01> ;
    ns1:precedes ns7:force_1 ;
    ns2:enforce-01.enforcer ns7:person_4 ;
    ns2:enforce-01.rule ns7:law_2 .

ns7:intense_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/intense-02> ;
    ns1:precedes ns7:force_1 ;
    ns2:intense-02.intense-thing ns7:standoff_1 .

ns7:pass_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/pass-03> ;
    ns1:precedes ns7:mount_1 ;
    ns2:pass-03.thing-passing ns7:moment_1 .

ns7:possible_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/possible-01> ;
    ns5:hasTruthValue ns5:False ;
    ns1:precedes ns7:plant_1 ;
    ns2:possible-01.thing-that-is-possible ns7:slow-down_1 .

ns7:special_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/special-02> ;
    ns1:precedes ns7:have-org-role_1 ;
    ns2:special-02.thing-that-is-unique ns7:conjunct_2 .

ns7:tense_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/tense-03> ;
    ns1:precedes ns7:unfold_1 ;
    ns2:tense-03.thing-tightening ns7:thriller_1 .

ns7:terrify_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/terrify-01> ;
    ns1:precedes ns7:manage_1 ;
    ns2:terrify-01.terrified-entity ns7:passenger_1 .

ns7:trap_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/trap-01> ;
    ns1:precedes ns7:manage_1 ;
    ns2:trap-01.entity-trapped ns7:passenger_1 ;
