<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/slow-down-03> rdfs:label "(cause to) move more slowly" ;
    rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/special-02> rdfs:label "unique" ;
    rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/tense-03> rdfs:label "be tight(er)" ;
