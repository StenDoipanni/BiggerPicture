    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0204f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/deal-01> rdfs:label "handle, deal with, transaction" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0373f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/desperate-02> rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/detonate-01> rdfs:label "cause something to explode" ;
    rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/enforce-01> rdfs:label "make sure the rules are followed" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0147f> .

