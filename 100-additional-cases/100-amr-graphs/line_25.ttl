ns3:defy-01.entity-defied a owl:ObjectProperty .

ns3:dream-01.dream a owl:ObjectProperty .

ns3:float-01.thing-floating a owl:ObjectProperty .

ns3:modern-02.thing-being-modernized a owl:ObjectProperty .

ns3:navigate-01.steerer a owl:ObjectProperty .

ns3:navigate-01.thing-steered a owl:ObjectProperty .

ns3:reflect-01.surface-doing-the-reflecting a owl:ObjectProperty .

ns3:resemble-01.copy a owl:ObjectProperty .

