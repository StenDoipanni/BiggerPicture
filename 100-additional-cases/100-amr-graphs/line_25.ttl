@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .

ns7:hasTruthValue a owl:ObjectProperty .

ns1:associatedWith a owl:ObjectProperty .

ns1:hasMember a owl:ObjectProperty .

ns1:hasQuality a owl:ObjectProperty .

ns1:precedes a owl:ObjectProperty .

ns4:clean_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/clean-04> ;
    ns1:precedes ns4:appear_1 ;
    ns3:clean-04.location-clean ns4:line_1 .

ns4:dark_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/dark-02> ;
    ns1:precedes ns4:wear_1 ;
    ns3:dark-02.thing-that-doesn-t-reflect-light ns4:suit_1 .

ns4:dark_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/dark-02> ;
    ns1:precedes ns4:wear_1 ;
    ns3:dark-02.thing-that-doesn-t-reflect-light ns4:hat_1 .

ns4:dream_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/dream-01> ;
    ns1:precedes ns4:navigate_1 ;
    ns3:dream-01.dream ns4:world_1 .

ns4:modern_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/modern-02> ;
    ns1:precedes ns4:appear_1 ;
    ns3:modern-02.thing-being-modernized ns4:interior_1 .

ns4:neuter_1 a ns4:Neuter,
        ns4:interior_1,
        owl:Thing .

ns4:reflect_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/reflect-01> ;
    ns1:precedes ns4:float_1 ;
    ns3:reflect-01.surface-doing-the-reflecting ns4:floor_1 .

ns4:resemble_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/resemble-01> ;
    ns1:precedes ns4:create_1 ;
    ns3:resemble-01.copy ns4:atmosphere_1 ;
    ns3:resemble-01.original ns4:dream_1 .

ns4:scene_1 a ns4:CorridorScene ;
    ns1:hasQuality ns4:Iconic ;
    ns6:part-of ns4:film_1 ;
    ns6:subevent ns4:navigate_1 .

ns4:share_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/share-01> ;
    ns1:precedes ns4:construct_1 ;
    ns3:share-01.sharer ns4:technology_1 ;
    ns3:share-01.thing-shared ns4:dream_3 .

ns4:white_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/white-03> ;
    ns1:precedes ns4:float_1 ;
    ns3:white-03.thing-that-is-white-in-color ns4:floor_1 .

ns4:white_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/white-03> ;
    ns1:precedes ns4:appear_1 ;
    ns3:white-03.thing-that-is-white-in-color ns4:wall_1 .

ns5:Location a owl:ObjectProperty .

ns5:Predicate a owl:ObjectProperty .

schema:name a owl:ObjectProperty .

ns6:manner a owl:ObjectProperty,
        ns2:SemanticRole ;
    owl:equivalentProperty <https://w3id.org/framester/data/propbank-3.4.0/GenericRole/manner> .

ns6:part-of a owl:ObjectProperty .

ns6:subevent a owl:ObjectProperty .

ns3:appear-02.thing-seeming a owl:ObjectProperty .

ns3:clean-04.location-clean a owl:ObjectProperty .

