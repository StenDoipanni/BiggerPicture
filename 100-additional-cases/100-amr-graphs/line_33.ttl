ns6:IceWall ns1:associatedWith ns6:Ice ;
    rdfs:subClassOf ns6:Wall .

ns6:conjunct_4 a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Conjunct> ;
    ns1:hasMember ns6:effort_1,
        ns6:focus_1 .

ns6:effort_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/effort-01> ;
