    ns1:associatedWith ns6:middle_1 ;
    ns6:positionBy ns6:grip_1 ;
    ns4:manner ns6:conjunct_3 ;
    ns3:position-01.location-or-position ns6:surface_1 ;
    ns3:position-01.thing-positioned ns6:person_2 .

ns6:surface_1 a ns6:Surface ;
    ns1:hasQuality ns6:Vertical .

ns6:tool_1 a ns6:Tool .

ns6:wall_1 a ns6:IceWall ;
