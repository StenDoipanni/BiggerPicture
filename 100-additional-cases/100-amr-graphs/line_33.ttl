ns1:associatedWith a owl:ObjectProperty .

ns1:hasDataValue a owl:DatatypeProperty .

ns1:hasMember a owl:ObjectProperty .

ns1:hasQuality a owl:ObjectProperty .

ns1:precedes a owl:ObjectProperty .

ns6:appear_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/appear-02> ;
    ns1:precedes ns6:require_1 ;
    ns3:appear-02.thing-seeming ns6:environment_1 ;
    ns3:appear-02.viewer ns6:challenge_1 .

ns6:black_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/black-04> ;
    ns1:precedes ns6:scale_1 ;
    ns3:black-04.thing-that-is-black-in-color ns6:harness_1 .

ns6:climb_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/climb-01> ;
    ns1:precedes ns6:scale_1 ;
    ns3:climb-01.climber ns6:person_1 .

ns6:climb_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/climb-01> ;
    ns1:precedes ns6:scale_1 ;
    ns5:Instrument ns6:tool_1 ;
    ns3:climb-01.thing-climbed ns6:IceWall .

ns6:climb_3 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/climb-01> ;
    ns1:precedes ns6:position_1 ;
    ns3:climb-01.climber ns6:person_2 .

ns6:demonstrate_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/demonstrate-01> ;
    ns1:precedes ns6:scale_1 ;
