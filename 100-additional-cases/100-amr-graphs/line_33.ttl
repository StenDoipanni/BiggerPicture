ns6:environment_1 a ns6:Environment ;
    ns1:hasQuality ns6:Alpine .

ns6:focus_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/focus-01> .

ns6:harness_1 a ns6:Harness .

ns6:headband_1 a ns6:Headband .

ns6:person_1 a ns6:Person ;
    ns6:with ns6:conjunct_1 .

