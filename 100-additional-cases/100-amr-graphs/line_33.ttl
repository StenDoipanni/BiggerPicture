ns6:freeze_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/freeze-01> ;
    ns1:precedes ns6:position_1 ;
    ns3:freeze-01.thing-freezing ns6:surface_1 .

ns6:intense_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/intense-02> ;
    ns1:precedes ns6:capture_1 ;
    ns3:intense-02.intense-thing ns6:effort_1 .

ns6:intense_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/intense-02> ;
    ns1:precedes ns6:capture_1 ;
    ns3:intense-02.intense-thing ns6:focus_1 .

ns6:red_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/red-02> ;
