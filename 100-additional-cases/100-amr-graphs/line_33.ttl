    ns3:raise-01.logical-subject ns6:arm_1 .

ns6:require_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/require-01> ;
    ns1:precedes ns6:capture_1 ;
    ns5:Location ns6:environment_1 ;
    ns3:require-01.requirer ns6:climb_4 ;
    ns3:require-01.thing-required ns6:conjunct_4 .

ns6:skill_1 a ns6:Skill ;
    ns1:hasQuality ns6:Technical .

