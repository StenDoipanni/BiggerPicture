    ns3:grip-01.thing-held ns6:axe_1 .

ns6:high_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/high-02> .

ns6:ice_1 a ns6:Ice .

ns6:lean_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/lean-01> ;
