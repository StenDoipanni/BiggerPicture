ns3:white-03.thing-that-is-white-in-color a owl:ObjectProperty .

ns2:subsumedUnder a owl:ObjectProperty .

ns6:AscentMiddle ns1:associatedWith ns6:Ascent ;
    rdfs:subClassOf ns6:Middle .

ns6:IceAxe ns1:associatedWith ns6:Ice ;
    rdfs:subClassOf ns6:Axe .

ns6:arm_1 a ns6:Arm ;
    ns1:hasDataValue 1.0 ;
    ns4:part-of ns6:person_2 .

ns6:axe_1 a ns6:IceAxe .

ns6:back_1 a ns6:Back .

ns6:body_1 a ns6:Body ;
    ns4:part-of ns6:person_2 .

ns6:challenge_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/challenge-01> .

ns6:climb_4 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/climb-01> ;
