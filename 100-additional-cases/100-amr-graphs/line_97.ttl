    ns4:subsumedUnder <http://verbatlas.org/0104f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/high-02> rdfs:label "in the upper ranges (altitude, pitch, etc)" ;
    rdfs:subClassOf ns2:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/major-02> rdfs:label "great in scope, extent, importance, etc" ;
    rdfs:subClassOf ns2:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/posture-01> rdfs:label "to assume a pose or mental attitude, assuming an exaggerated pose or attitude" ;
    rdfs:subClassOf ns2:Event ;
