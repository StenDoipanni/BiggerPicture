ns2:hasMember a owl:ObjectProperty .

ns2:hasQuality a owl:ObjectProperty .

ns2:precedes a owl:ObjectProperty .

ns6:appear_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/appear-02> ;
    ns1:appear-02.thing-seeming ns6:disjunct_1 .

ns6:depict_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/depict-01> ;
    ns1:depict-01.agent ns6:neuter_1 ;
    ns1:depict-01.attribute ns6:sit_1 ;
    ns1:depict-01.thing-described ns6:scenario_1 .

ns6:harsh_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/harsh-02> ;
    ns2:precedes ns6:stretch_1 ;
    ns1:harsh-02.harsh-entity ns6:terrain_1 .

ns6:harsh_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/harsh-02> ;
    ns2:precedes ns6:capture_1 ;
    ns1:harsh-02.harsh-entity ns6:condition_1 .

ns6:haze_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/haze-01> ;
    ns2:precedes ns6:stretch_1 ;
    ns1:haze-01.entity-hazed ns6:sky_1 .

ns6:load_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/load-01> ;
    ns2:precedes ns6:stretch_1 ;
    ns1:load-01.beast-of-burden ns6:sky_1 ;
    ns1:load-01.cargo ns6:dust_1 .

ns6:red_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/red-02> ;
    ns2:precedes ns6:survive_1 ;
    ns1:red-02.red-entity ns6:planet_1 .

ns6:rust_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/rust-01> ;
    ns2:precedes ns6:sit_1 ;
    ns1:rust-01.rusty-thing ns6:surface_1 .

ns6:tower_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/tower-01> ;
    ns2:precedes ns6:surround_1 ;
    ns1:tower-01.entity-towered-over ns6:formation_1 .

ns6:wear_2 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/wear-06> ;
    ns2:precedes ns6:wear_1 ;
    ns1:wear-06.thing-eroded ns6:conjunct_1 .

ns4:Location a owl:ObjectProperty .

schema:name a owl:ObjectProperty .

