<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#person_3> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Person> ;
    ns6:hasQuantifier <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#some_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#suggest_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/suggest-01> ;
