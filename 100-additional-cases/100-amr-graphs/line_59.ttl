ns2:associatedWith a owl:ObjectProperty .

ns2:hasMember a owl:ObjectProperty .

ns2:hasQuality a owl:ObjectProperty .

ns2:precedes a owl:ObjectProperty .

ns6:cold_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/cold-01> ;
    ns2:precedes ns6:have_1 ;
    ns1:cold-01.thing-with-few-degrees ns6:light_1 .

ns6:extend_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/extend-01> ;
    ns2:precedes ns6:stand_1 ;
    ns1:extend-01.agent ns6:man_1 ;
    ns1:extend-01.patient ns6:arm_1 .

ns6:intense_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/intense-02> ;
    ns2:precedes ns6:be-located-at_1 ;
    ns1:intense-02.intense-thing ns6:scene_1 .

ns6:possible_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/possible-01> ;
    ns2:precedes ns6:be-located-at_1 ;
    ns1:possible-01.thing-that-is-possible ns6:disjunct_1 .

ns6:red_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/red-02> ;
    ns2:precedes ns6:wear_1 ;
    ns1:red-02.red-entity ns6:jacket_1 .

ns6:see_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/see-01> ;
    ns2:precedes ns6:have_1 ;
    ns4:Location ns6:background_1 ;
    ns1:see-01.thing-viewed ns6:conjunct_2 .

ns6:suggest_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/suggest-01> ;
    ns1:suggest-01.sayer ns6:conjunct_3 ;
    ns1:suggest-01.utterance ns6:be-located-at_1 .

ns6:tint_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/tint-01> ;
    ns2:precedes ns6:have_1 ;
    ns1:tint-01.the-color-itself ns6:blue_1 ;
    ns1:tint-01.thing-with-color ns6:light_1 .

ns6:white_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/white-03> ;
    ns2:precedes ns6:stand_1 ;
    ns1:white-03.thing-that-is-white-in-color ns6:hair_1 .

