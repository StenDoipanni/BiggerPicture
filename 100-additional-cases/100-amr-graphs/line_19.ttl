    rdfs:subClassOf ns6:Container .

ns6:Neuter a owl:Thing .

ns6:OrSetting ns3:associatedWith ns6:Or ;
    rdfs:subClassOf ns6:Setting .

ns6:appear_1 a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/appear-02> ;
