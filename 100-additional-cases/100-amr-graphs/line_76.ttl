ns1:associatedWith a owl:ObjectProperty .

ns1:hasMember a owl:ObjectProperty .

ns1:hasQuality a owl:ObjectProperty .

ns1:precedes a owl:ObjectProperty .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#conjunct_1> a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Conjunct> ;
    ns1:hasMember <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#restrain_1>,
        <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#seat_1>,
