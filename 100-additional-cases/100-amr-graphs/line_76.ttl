<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/interrogate-01> rdfs:label "question closely" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0330f> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#male_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Male> ;
    ns1:precedes <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#suggest_1> ;
    ns5:Location <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#custody_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#man_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Man> ;
    ns1:hasQuality <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Alone> .

