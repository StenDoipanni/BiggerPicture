<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#typical_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/typical-02> ;
    ns1:precedes <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#feature_1> ;
    ns2:typical-02.entity-arg1-is-typical-for <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#facility_1> ;
    ns2:typical-02.usual-thing <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#atmosphere_1> .

