<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#empty_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/empty-02> ;
    ns1:precedes <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#seat_1> ;
