<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#restrain_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/restrain-01> ;
    ns2:restrain-01.thing-being-restrained <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#man_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#room_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Room> ;
    ns1:hasQuality <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#interrogate_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#setting_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Setting> ;
    ns1:hasQuality <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Austere> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#sit_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/sit-01> ;
    ns2:sit-01.location-or-position <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#room_1> ;
    ns2:sit-01.thing-sitting <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#man_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#space_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Space> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#suggest_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/suggest-01> ;
    ns2:suggest-01.sayer <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#conjunct_3> ;
    ns2:suggest-01.utterance <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#conjunct_4> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#table_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Table> ;
    ns1:hasQuality <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Across> ;
    ns5:Location <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#chair_1> ;
    ns4:consist-of <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#metal_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#wait_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/wait-01> ;
    ns2:wait-01.thing-waited-for <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#arrive_1> ;
    ns2:wait-01.wait-er <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#male_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#wood_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Wood> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/arrive-01> rdfs:label "move, come to" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0504f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/dark-02> rdfs:label "not reflecting much, if any, light" ;
    rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/detain-01> rdfs:label "to keep in custody or delay" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0578f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/empty-02> rdfs:label "containing nothing" ;
    rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/feature-01> rdfs:label "bring into prominence" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0104f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/isolate-01> rdfs:label "to set apart, (causing to be) solitary" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0307f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/posture-01> rdfs:label "to assume a pose or mental attitude, assuming an exaggerated pose or attitude" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0017f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/question-01> rdfs:label "ask a question (of a listener)" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0330f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/restrain-01> rdfs:label "stop, prevent, holding back" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0126f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/seat-01> rdfs:label "to place in a seat, provide seats" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0502f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/sit-01> rdfs:label "be in a position" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0523f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/suggest-01> rdfs:label "say, giving of advice" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0227f> .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/typical-02> rdfs:label "usual" ;
    rdfs:subClassOf ns1:Event .

<https://w3id.org/framester/data/propbank-3.4.0/RoleSet/wait-01> rdfs:label "wait, delay movement or action" ;
    rdfs:subClassOf ns1:Event ;
    ns3:subsumedUnder <http://verbatlas.org/0621f> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#arrive_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/arrive-01> ;
    ns2:arrive-01.entity-in-motion <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#person_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#atmosphere_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#ClinicAtmosphere> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#chair_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Chair> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#custody_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Custody> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#feature_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/feature-01> ;
    ns2:feature-01.cause-of-prominence <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#setting_1> ;
    ns2:feature-01.thing-featured <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#conjunct_2> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#person_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Person> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#seat_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/seat-01> ;
    ns2:seat-01.entity-seated <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#man_1> ;
    ns2:seat-01.location <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#table_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#wall_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Wall> ;
