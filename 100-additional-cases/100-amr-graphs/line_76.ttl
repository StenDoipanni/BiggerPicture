ns2:wait-01.thing-waited-for a owl:ObjectProperty .

ns2:wait-01.wait-er a owl:ObjectProperty .

ns3:subsumedUnder a owl:ObjectProperty .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#ClinicAtmosphere> ns1:associatedWith <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Clinic> ;
    rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Atmosphere> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#PoliceFacility> ns1:associatedWith <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Police> ;
    rdfs:subClassOf <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Facility> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#conjunct_2> a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Conjunct> ;
