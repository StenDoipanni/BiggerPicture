<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#interrogate_2> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/interrogate-01> ;
    ns1:precedes <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#arrive_1> ;
