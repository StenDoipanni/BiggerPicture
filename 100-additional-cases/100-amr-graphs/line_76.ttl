        <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#wall_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#conjunct_3> a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Conjunct> ;
    ns1:hasMember <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#isolate_1>,
        <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#posture_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#conjunct_4> a <http://www.ontologydesignpatterns.org/ont/boxer/boxing.owl#Conjunct> ;
    ns1:hasMember <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#custody_1>,
        <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#question_1>,
        <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#wait_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#detain_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/detain-01> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#facility_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#PoliceFacility> ;
    ns1:hasQuality <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#detain_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#interrogate_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/interrogate-01> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#isolate_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/isolate-01> ;
    ns2:isolate-01.entity-isolated <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#space_1> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#metal_1> a <http://www.ontologydesignpatterns.org/ont/fred/domain.owl#Metal> .

<http://www.ontologydesignpatterns.org/ont/fred/domain.owl#posture_1> a <https://w3id.org/framester/data/propbank-3.4.0/RoleSet/posture-01> ;
